# Database (SQLite default — no external DB needed)
TRACKER_DATABASE_URL=sqlite+aiosqlite:///./tracker.db

# Scraper
TRACKER_PLAYWRIGHT_HEADLESS=true
TRACKER_PAGE_LOAD_TIMEOUT=30
TRACKER_RETRY_COUNT=3
TRACKER_RETRY_BASE_DELAY=2.0

# Scheduler
TRACKER_CRAWL_INTERVAL_MINUTES=360
TRACKER_CRAWL_CONCURRENCY=1

# Marketplace
TRACKER_SUPPORTED_MARKETPLACES=["AE","SA","AU"]

# Logging
TRACKER_LOG_LEVEL=INFO

# AU Proxy (optional — needed for AU marketplace from non-AU IP)
# Example: http://user:pass@au.smartproxy.com:10000
# Free proxy example: http://au-proxy-ip:port
TRACKER_AU_PROXY_URL=
